{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "astro": {
      "type": "remote",
      "url": "https://mcp.docs.astro.build/mcp",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest",
        "--executable-path",
        "/mnt/c/Program Files/Google/Chrome/Application/chrome.exe",
        "--extension",
        "--browser",
        "chrome"
      ],
      "enabled": true
    },
    "shadcn": {
      "type": "local",
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true
    }
  }
}
