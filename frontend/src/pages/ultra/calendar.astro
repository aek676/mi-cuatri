---
import EventCalendar from '@/components/EventCalendar';
import AppLayout from '@/layouts/AppLayout.astro';
import type { CalendarItemDto } from '@/lib/api';

const api = Astro.locals.api!;

let events: CalendarItemDto[] = [];

try {
  const [calendarResult, eventsResult] = await Promise.allSettled([
    api.api.calendarList({
      currentDate: new Date().toISOString(),
    }),
    api.api.eventsList(),
  ]);

  const calendarEvents = calendarResult.status === 'fulfilled' ? calendarResult.value.data || [] : [];
  const personalEvents = eventsResult.status === 'fulfilled' ? eventsResult.value.data || [] : [];

  const transformedPersonalEvents: CalendarItemDto[] = personalEvents.map((event) => ({
    calendarid: event.id,
    title: event.title,
    start: event.start,
    end: event.end,
    subject: event.subject || '',
    location: event.location,
    color: event.color,
    category: event.category,
  }));

  events = [...calendarEvents, ...transformedPersonalEvents];
} catch (error) {
  console.error('Error loading events:', error);
}
---

<AppLayout>
  <div class="flex-1 w-full border rounded-lg shadow-sm bg-card overflow-auto">
    <EventCalendar client:load events={events} />
  </div>
</AppLayout>
